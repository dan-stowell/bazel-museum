load("//bazel_runner:defs.bzl", "HERMETIC_PYTHON_FLAGS", "hermetic_llvm_project_modification")
load("//projects/lcm:project.bzl", "LCM_PROJECT")

# lcm's glib dependency runs py_binary codegen tools (RunBinary) during the
# build; the script bootstrap keeps them off the system python3, which RBE
# workers lack. lcm's MODULE already declares rules_python.
hermetic_llvm_project_modification(
    project = LCM_PROJECT,
    toolchains = [HERMETIC_PYTHON_FLAGS],
)
